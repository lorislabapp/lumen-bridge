<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- aps-environment: required by Apple for any tvOS app that
	     declares CloudKit. Without it, ASC export fails with
	     "Missing Entitlement … aps-environment". -->
	<key>aps-environment</key>
	<string>production</string>
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.com.lorislabapp.lumenbridge</string>
	</array>
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudKit</string>
		<string>CloudDocuments</string>
	</array>
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)$(CFBundleIdentifier)</string>
	<!-- Keychain access group: must match the macOS Bridge so iCloud
	     Keychain can sync the MQTT broker password across the user's
	     devices (same Apple ID). Without this, the Apple TV install
	     reads a nil password from `MQTTCredentialsKeychain.get()` even
	     when the macOS Bridge has stored one — host/port/username
	     arrive via KVS but the password doesn't, so the EMQX
	     connection fails silently with auth refused on Apple TV. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.lorislabapp.lumenbridge</string>
	</array>
</dict>
</plist>
